@* Styles for component *@
<style>
    .svg-logo {
        background-color: #ffffff;
        border-radius: 50%;
        aspect-ratio: 1 / 1;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }

    .svg-logo svg { 
            width: 70%;
            height: 70%;
            max-width: 100%;
            max-height: 100%;
    }

    .svg-border {
        border: 1px solid black;
    }
</style>


<div>
    @* Link and Default SVG image included for profile picture *@
    <a href=/dashboard/profile >  
        <div class="svg-logo @(border ? "svg-border" : "")" style="justify-self: center; width:@(width)px; height:@(width)px;">
            @* FUTURE IDEA - run a conditional if statement to see if this students has a profile picture. 
            If so, use the profile picture (with the same dimensions)
            If not, then us the default svg image.*@


            @* SVG Image *@
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                <!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com 
                License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                <path d="M224 248a120 120 0 1 0 0-240 120 120 0 1 0 0 240zm-29.7 56C95.8 304 16 383.8 16 
                482.3 16 498.7 29.3 512 45.7 512l356.6 0c16.4 0 29.7-13.3 29.7-29.7 
                0-98.5-79.8-178.3-178.3-178.3l-59.4 0z"/>
            </svg>
        </div>
    </a>
</div>

@code {
    @* A customizable width that has a preset default. *@
    [Parameter]
    public int width { get; set; } = 30;
    [Parameter]
    public bool border { get; set; } = false;


}

