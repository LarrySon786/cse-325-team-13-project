@page "/dashboard/schedule"
@using StudentPortal.Components.Shared.Models
@using StudentPortal.Components.Shared.Services
@inject StudentSchedule schedule
@implements IDisposable



<h1>My Schedule</h1>

@if (schedule.classes.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Class Code</th>
                <th>Name</th>
                <th>Credits</th>
            </tr>
        </thead>

        <tbody>
            @foreach (Class item in schedule.classes)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@item.Credits</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>You are not registered for any classes. You can register <a href="/dashboard/class-registration">here</a>.</p>
}


<button class="btn btn-primary" @onclick="addTestClass">Add Test Class</button>



@code {
    protected override void OnInitialized() 
    {
        schedule.OnChange += HandleChange;
    }
    private void HandleChange() {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() {
        schedule.OnChange -= HandleChange;
    }

    private void addTestClass()
    {
        schedule.registerClass(new Class
        {
            Code = "TEST101",
            Name = "Test Class",
            Credits = 3
        });
    }

}