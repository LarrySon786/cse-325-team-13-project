@code{

    DateOnly registrationDeadline = DateOnly.FromDateTime(DateTime.Now.AddDays(7));
    private List<Class> classes = new();

    protected override void OnInitialized()
        {
            if (!studentAccount.IsLoggedIn()) {
                Navigation.NavigateTo("/login");
                return;
            }
            try {
                classes = _context.GetClassesEnrolled(studentAccount.studentProfile.Id);
            }
            catch (Exception ex) {
                Console.WriteLine($"Could not retrieve classes from database. Error: {ex}");
            }
            
            DateOnly registrationDeadline = DateOnly.FromDateTime(DateTime.Now.AddDays(7));
        }
}