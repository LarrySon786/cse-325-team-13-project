@page "/"

<PageTitle>Student Portal</PageTitle>


@* Welcome Display with login and register links *@
<div class="container">
    <div>
        <h1 class="lower-emphasis">Welcome to</h1>
        <h1>The Student Portal</h1>
    </div>
    <div class="image-container">
        <a href="/">
            <img src="/images/byu-logo-white.webp" alt="BYU Pathway Logo" width="300"/>
