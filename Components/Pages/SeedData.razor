
@page "/seed-data"
@using System.Text.Json
@inject AppDbContext _context
@rendermode InteractiveServer

@if (seeding) {
  <p>Seeding Database...</p>
} else {
  <button @onclick="SeedDatabase">Seed Database</button>
  <p>@Message</p>
  @* <p>@test</p> *@
}


@code {
    private string Message = "";
    //private string test = "";
    private bool seeding = false;

    protected async Task SeedDatabase()
    {
        seeding = true;
        try
        {
            // Reset Database
            await _context.Database.EnsureDeletedAsync();
            await _context.Database.EnsureCreatedAsync();

            _context.AddClasses(
                ("code1", "name1", 1, "instructor1", "description1", "startDate1", "endDate1", 
                new Dictionary<DayOfWeek, TimeOnly>
                {
                    { DayOfWeek.Monday, new TimeOnly(9, 0) },
                    { DayOfWeek.Wednesday, new TimeOnly(9, 0) }
                }),
                ("code2", "name2", 1, "instructor2", "description2", "startDate2", "endDate2", 
                new Dictionary<DayOfWeek, TimeOnly>
                {
                    { DayOfWeek.Tuesday, new TimeOnly(11, 30) },
                    { DayOfWeek.Wednesday, new TimeOnly(9, 0) }
                }),
                ("code3", "name3", 1, "instructor3", "description3", "startDate3", "endDate3", new()),
                ("code4", "name4", 1, "instructor4", "description4", "startDate4", "endDate4", new()),
                ("code5", "name5", 1, "instructor5", "description5", "startDate5", "endDate5", new())
            );

            // Add initial content
            _context.AddStudents(
                ("fname1", "lname1", "student1@example.com", "000-000-0001", "bio1", "password1"),
                ("fname2", "lname2", "student2@example.com", "000-000-0002", "bio2", "password2"),
                ("fname3", "lname3", "student3@example.com", "000-000-0003", "bio3", "password3")
            );

            _context.RegisterClasses(
                (1, 5),
                (3, 4)
            );

            await _context.SaveChangesAsync();

            Message = "Database reset and seeded!";
        }
        catch (Exception e)
        {
            Message = $"Error: {e.Message}";
        }
        seeding = false;

        //test = JsonSerializer.Serialize(_context.Students.ToList());
    }
}
